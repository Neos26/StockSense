@inherits LayoutComponentBase
@using StockSense.Client.Layout

<div style="display: flex; flex-direction: column; height: 100vh; background-color: var(--background); font-family: var(--font-sans);">
    <NavBar />
    <div style="display: flex; flex: 1; overflow: hidden;">

        <aside style="width: 14rem; flex-shrink: 0; border-right: 1px solid var(--border); background-color: var(--card); padding: var(--space-6) var(--space-4); overflow-y: auto;">
            <p style="font-size: var(--text-xs); font-weight: var(--font-semibold); color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 var(--space-3) var(--space-3);">Account</p>
            <ManageNavMenu />
        </aside>

        <main style="flex: 1; overflow-y: auto; padding: var(--space-8);">
            <div style="max-width: 640px;">
                @Body
            </div>
        </main>

    </div>
</div>