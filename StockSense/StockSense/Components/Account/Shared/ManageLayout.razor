@inherits LayoutComponentBase
@using StockSense.Client.Layout

<AuthorizeView Roles="Admin">

    @* ---- ADMINS: Full width Body within MainLayout (Sidebar already exists in MainLayout) ---- *@
    <Authorized>
        <LayoutView Layout="@typeof(MainLayout)">
            <main style="flex: 1; overflow-y: auto; padding: 2rem;">
                <div style="max-width: 640px;">
                    @Body
                </div>
            </main>
        </LayoutView>
    </Authorized>

    @* ---- REGULAR USERS: Dashboard style within EmptyLayout ---- *@
    <NotAuthorized>
        <LayoutView Layout="@typeof(EmptyLayout)">
            <div style="display: flex; height: 100%; overflow: hidden; background-color: var(--background); font-family: var(--font-sans);">

                <aside style="width: 14rem; flex-shrink: 0; border-right: 1px solid var(--border); background-color: var(--card); overflow-y: auto;">
                    <ManageNavMenu />
                </aside>

                <main style="flex: 1; overflow-y: auto; padding: 2rem;">
                    <div style="max-width: 640px;">
                        @Body
                    </div>
                </main>

            </div>
        </LayoutView>
    </NotAuthorized>

</AuthorizeView>