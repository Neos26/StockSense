@using Microsoft.AspNetCore.Identity
@using StockSense.Data
@inject SignInManager<ApplicationUser> SignInManager

<nav style="display: flex; flex-direction: column; gap: var(--space-1);">
    <NavLink href="Account/Manage" Match="NavLinkMatch.All" style="display: block; padding: var(--space-2) var(--space-3); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground); text-decoration: none;" ActiveClass="manage-nav-active">
        Profile
    </NavLink>
    <NavLink href="Account/Manage/Email" style="display: block; padding: var(--space-2) var(--space-3); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground); text-decoration: none;" ActiveClass="manage-nav-active">
        Email
    </NavLink>
    <NavLink href="Account/Manage/ChangePassword" style="display: block; padding: var(--space-2) var(--space-3); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground); text-decoration: none;" ActiveClass="manage-nav-active">
        Password
    </NavLink>
    @if (hasExternalLogins)
    {
        <NavLink href="Account/Manage/ExternalLogins" style="display: block; padding: var(--space-2) var(--space-3); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground); text-decoration: none;" ActiveClass="manage-nav-active">
            External Logins
        </NavLink>
    }
    <NavLink href="Account/Manage/TwoFactorAuthentication" style="display: block; padding: var(--space-2) var(--space-3); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground); text-decoration: none;" ActiveClass="manage-nav-active">
        Two-Factor Auth
    </NavLink>
    <NavLink href="Account/Manage/PersonalData" style="display: block; padding: var(--space-2) var(--space-3); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground); text-decoration: none;" ActiveClass="manage-nav-active">
        Personal Data
    </NavLink>
</nav>

<style>
    .manage-nav-active {
        background-color: var(--secondary) !important;
        color: var(--secondary-foreground) !important;
    }
    nav a:hover:not(.manage-nav-active) {
        background-color: var(--accent);
        color: var(--accent-foreground);
    }
</style>

@code {
    private bool hasExternalLogins;

    protected override async Task OnInitializedAsync()
    {
        hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    }
}