@using Microsoft.AspNetCore.Identity
@using StockSense.Data
@inject SignInManager<ApplicationUser> SignInManager

<BbSidebarContent>
    <BbSidebarGroup>
        <BbSidebarGroupLabel>Account</BbSidebarGroupLabel>
        <BbSidebarMenu>
            <BbSidebarMenuItem>
                <BbSidebarMenuButton IsActive="@IsExactPath("Account/Manage")" href="Account/Manage">
                    Profile
                </BbSidebarMenuButton>
            </BbSidebarMenuItem>
            <BbSidebarMenuItem>
                <BbSidebarMenuButton IsActive="@IsExactPath("Account/Manage/Email")" href="Account/Manage/Email">
                    Email
                </BbSidebarMenuButton>
            </BbSidebarMenuItem>
            <BbSidebarMenuItem>
                <BbSidebarMenuButton IsActive="@IsExactPath("Account/Manage/ChangePassword")" href="Account/Manage/ChangePassword">
                    Password
                </BbSidebarMenuButton>
            </BbSidebarMenuItem>
            @if (hasExternalLogins)
            {
                <BbSidebarMenuItem>
                    <BbSidebarMenuButton IsActive="@IsExactPath("Account/Manage/ExternalLogins")" href="Account/Manage/ExternalLogins">
                        External Logins
                    </BbSidebarMenuButton>
                </BbSidebarMenuItem>
            }
            <BbSidebarMenuItem>
                <BbSidebarMenuButton IsActive="@IsExactPath("Account/Manage/TwoFactorAuthentication")" href="Account/Manage/TwoFactorAuthentication">
                    Two-Factor Auth
                </BbSidebarMenuButton>
            </BbSidebarMenuItem>
            <BbSidebarMenuItem>
                <BbSidebarMenuButton IsActive="@IsExactPath("Account/Manage/PersonalData")" href="Account/Manage/PersonalData">
                    Personal Data
                </BbSidebarMenuButton>
            </BbSidebarMenuItem>
        </BbSidebarMenu>
    </BbSidebarGroup>
</BbSidebarContent>

@code {
    private bool hasExternalLogins;

    [Inject] private NavigationManager NavigationManager { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    }

    private bool IsExactPath(string path) =>
        NavigationManager.ToBaseRelativePath(NavigationManager.Uri)
            .Equals(path, StringComparison.OrdinalIgnoreCase);
}